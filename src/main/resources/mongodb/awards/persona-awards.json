{
  "collection": "Awards",
  "pipeline": [
    {
      "$match": {
        "workflow.step": "validated"
      }
    },
    {
      "$unwind": "$awardHolders"
    },
    {
      "$match": {
        "awardHolders.person.uuid": "__PERSON_UUID__"
      }
    },
    {
      "$unwind": {
        "path": "$fundings",
        "preserveNullAndEmptyArrays": true
      }
    },
    {
      "$unwind": {
        "path": "$fundings.fundingCollaborators",
        "preserveNullAndEmptyArrays": true
      }
    },
    {
      "$match": {
        "fundings.fundingCollaborators.collaborator.uuid": "__COLLABORATOR_UUID__"
      }
    },
    {
      "$addFields": {
        "managingOrganizationUuid": "$managingOrganization.uuid"
      }
    },
    {
      "$lookup": {
        "from": "Organizations",
        "localField": "managingOrganizationUuid",
        "foreignField": "uuid",
        "as": "managing_org_info"
      }
    },
    {
      "$unwind": {
        "path": "$managing_org_info",
        "preserveNullAndEmptyArrays": true
      }
    },
    {
      "$addFields": {
        "coManagingUuids": {
          "$setDifference": [
            {
              "$map": {
                "input": { "$ifNull": ["$coManagingOrganizations", []] },
                "as": "org",
                "in": "$$org.uuid"
              }
            },
            ["$managingOrganizationUuid"]
          ]
        }
      }
    },
    {
      "$lookup": {
        "from": "Organizations",
        "localField": "coManagingUuids",
        "foreignField": "uuid",
        "as": "co_managing_org_info"
      }
    },
    {
      "$addFields": {
        "anyo": { "$year": "$awardDate" },
        "importe_partida": {
          "$convert": {
            "input": "$fundings.fundingCollaborators.institutionalPart.value",
            "to": "double",
            "onError": 0,
            "onNull": 0
          }
        }
      }
    },
    {
      "$project": {
        "_id": 0,
        "awardUuid": "$uuid",
        "anyo": 1,
        "vigenciaInicio": "$actualPeriod.startDate",
        "vigenciaFin": "$actualPeriod.endDate",
        "tipoAward": "$type.term.ca_ES",
        "titulo": {
          "$ifNull": [
            "$title.es_ES",
            { "$ifNull": ["$title.en_GB", "Sin título"] }
          ]
        },
        "rol": "$awardHolders.role.term.es_ES",
        "importe_partida": 1,
        "managingOrganization": {
          "$ifNull": [
            "$managing_org_info.name.ca_ES",
            {
              "$ifNull": [
                "$managing_org_info.name.es_ES",
                {
                  "$ifNull": [
                    "$managing_org_info.name.en_GB",
                    { "$ifNull": ["$managingOrganizationUuid", "-"] }
                  ]
                }
              ]
            }
          ]
        },
        "comanagingOrganization": {
          "$let": {
            "vars": {
              "coManagingNames": {
                "$filter": {
                  "input": {
                    "$map": {
                      "input": { "$ifNull": ["$co_managing_org_info", []] },
                      "as": "org",
                      "in": {
                        "$ifNull": [
                          "$$org.name.ca_ES",
                          {
                            "$ifNull": [
                              "$$org.name.es_ES",
                              {
                                "$ifNull": [
                                  "$$org.name.en_GB",
                                  ""
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    }
                  },
                  "as": "name",
                  "cond": { "$ne": ["$$name", ""] }
                }
              },
              "coManagingUuidsText": {
                "$reduce": {
                  "input": {
                    "$filter": {
                      "input": { "$ifNull": ["$coManagingUuids", []] },
                      "as": "u",
                      "cond": { "$ne": ["$$u", ""] }
                    }
                  },
                  "initialValue": "",
                  "in": {
                    "$cond": [
                      { "$eq": ["$$value", ""] },
                      "$$this",
                      { "$concat": ["$$value", ", ", "$$this"] }
                    ]
                  }
                }
              }
            },
            "in": {
              "$cond": [
                { "$gt": [{ "$size": "$$coManagingNames" }, 0] },
                {
                  "$reduce": {
                    "input": "$$coManagingNames",
                    "initialValue": "",
                    "in": {
                      "$cond": [
                        { "$eq": ["$$value", ""] },
                        "$$this",
                        { "$concat": ["$$value", ", ", "$$this"] }
                      ]
                    }
                  }
                },
                {
                  "$cond": [
                    { "$ne": ["$$coManagingUuidsText", ""] },
                    "$$coManagingUuidsText",
                    "-"
                  ]
                }
              ]
            }
          }
        }
      }
    },
    {
      "$group": {
        "_id": "$awardUuid",
        "anyo": { "$first": "$anyo" },
        "vigenciaInicio": { "$first": "$vigenciaInicio" },
        "vigenciaFin": { "$first": "$vigenciaFin" },
        "tipoAward": { "$first": "$tipoAward" },
        "titulo": { "$first": "$titulo" },
        "rol": { "$first": "$rol" },
        "institutionalPart": { "$sum": "$importe_partida" },
        "managingOrganization": { "$first": "$managingOrganization" },
        "comanagingOrganization": { "$first": "$comanagingOrganization" }
      }
    },
    {
      "$project": {
        "_id": 0,
        "awardUuid": "$_id",
        "anyo": 1,
        "vigenciaInicio": 1,
        "vigenciaFin": 1,
        "tipoAward": 1,
        "titulo": 1,
        "rol": 1,
        "institutionalPart": { "$round": ["$institutionalPart", 2] },
        "managingOrganization": 1,
        "comanagingOrganization": 1
      }
    },
    {
      "$sort": {
        "anyo": -1,
        "titulo": 1
      }
    }
  ]
}